{
  "name": "pcontext-monorepo",
  "module": "index.ts",
  "private": true,
  "scripts": {
    "dev:api": "bun run --filter @pcontext/api dev",
    "dev:server": "bun run --filter @pcontext/server dev",
    "dev:web": "bun run --filter @pcontext/web dev",
    "db:generate": "bun run --filter @pcontext/api db:generate",
    "mcp-inspect": "bun run --filter @pcontext/api mcp-inspector",
    "commit": "git-cz",
    "commit:lint": "commitlint --edit"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {},
  "devDependencies": {
    "@antfu/eslint-config": "^5.1.0",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@modelcontextprotocol/inspector": "^0.20.0",
    "@react-router/dev": "7.10.1",
    "@types/bun": "latest",
    "@types/minimist": "^1.2.5",
    "@types/node": "^22",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.15",
    "autoprefixer": "^10.4.22",
    "bun-types": "^1.3.4",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.32.0",
    "eslint-plugin-format": "^1.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.4",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.6",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.13",
    "tailwindcss-animate": "^1.0.7",
    "tsdown": "^0.20.3",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vite-tsconfig-paths": "^5.1.1",
    "vitest": "^4.0.15"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "patchedDependencies": {
    "@llamaindex/openai@0.4.22": "patches/@llamaindex%2Fopenai@0.4.22.patch"
  }
