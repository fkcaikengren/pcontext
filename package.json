{
  "name": "pcontext-monorepo",
  "module": "index.ts",
  "private": true,
  "version": "0.0.2",
  "scripts": {
    "dev:api": "bun run --filter @pcontext/api dev",
    "dev:web": "bun run --filter @pcontext/web dev",
    "build": "./scripts/build.sh",
    "db:generate": "bun run --filter @pcontext/api db:generate",
    "mcp-inspect": "bun run --filter @pcontext/api mcp-inspector",
    "commit": "git-cz",
    "commit:lint": "commitlint --edit",
    "ci:version": "./scripts/version.sh",
    "ci:publish": "./scripts/build.sh && ./scripts/publish.sh"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "hono": "^4.12.5"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.4.1",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@modelcontextprotocol/inspector": "^0.20.0",
    "@react-router/dev": "7.10.1",
    "@types/bun": "latest",
    "@types/minimist": "^1.2.5",
    "@types/node": "^22.19.15",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.27",
    "bun-types": "^1.3.10",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.4",
    "eslint-plugin-format": "^1.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.8",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tsdown": "^0.20.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.18"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "patchedDependencies": {
    "@llamaindex/openai@0.4.22": "patches/@llamaindex%2Fopenai@0.4.22.patch"
  }
}
