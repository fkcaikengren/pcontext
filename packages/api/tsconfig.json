{
  "extends": "../../tsconfig.node.json",
  "compilerOptions": {
    "composite": true, // 必须开启（for reference of web , for hono rpc）
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@pcontext/*": ["./node_modules/@pcontext/*"]
    },
    "resolveJsonModule": true,
    "strict": true,
    "declaration": true, // 必须生成声明文件
    "declarationMap": true, // 建议开启，方便点击跳转到源码
    "noEmit": false, // 允许生成js文件
    "outDir": "./dist",
    "sourceMap": false, // 不生成 .js.map 文件
    "esModuleInterop": true
  },
  "references": [
    { "path": "../shared" }
  ],
  "include": [
    "drizzle-sqlite.config.ts",
    "drizzle-pg.config.ts",
    "src/**/*.ts",
    "scripts/**/*.ts"
  ]
}
