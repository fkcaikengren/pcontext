{
  "name": "@pcontext/api",
  "type": "module",
  "version": "0.0.2",
  "description": "PContext API - Backend API service for PContext",
  "author": "fkcaikengren",
  "license": "MIT",
  "homepage": "https://github.com/fkcaikengren/pcontext#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fkcaikengren/pcontext.git",
    "directory": "packages/api"
  },
  "bugs": {
    "url": "https://github.com/fkcaikengren/pcontext/issues"
  },
  "keywords": [
    "pcontext",
    "api",
    "hono"
  ],
  "exports": {
    ".": "./dist/index.mjs"
  },
  "module": "./dist/index.mjs",
  "public": true,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "NODE_ENV=development bun run --hot src/dev.ts --elide-lines=1000",
    "clean": "rm -rf dist",
    "build": "NODE_ENV=production tsdown && cp -r src/shared/db/migrations dist/shared/db/migrations",
    "test": "NODE_ENV=test bun run src/index.ts",
    "mcp-inspector": "mcp-inspector",
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "db:generate": "bun run scripts/drizzle-generate.ts"
  },
  "dependencies": {
    "@ai-sdk/llamaindex": "^1.0.106",
    "@hono/node-server": "^1.19.6",
    "@hono/vite-dev-server": "^0.23.0",
    "@hono/zod-validator": "^0.7.2",
    "@libsql/client": "^0.15.15",
    "@llamaindex/milvus": "^0.1.31",
    "@llamaindex/openai": "0.4.22",
    "@llamaindex/readers": "~3.1.4",
    "@llamaindex/tools": "~0.1.2",
    "@llamaindex/workflow": "~1.1.8",
    "@mendable/firecrawl-js": "^4.13.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@pcontext/shared": "workspace:*",
    "@zilliz/milvus2-sdk-node": "^2.6.5",
    "ai": "^6.0.86",
    "argon2": "^0.43.1",
    "bullmq": "^5.70.1",
    "casbin": "^5.45.0",
    "class-variance-authority": "^0.7.1",
    "croner": "^9.1.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.0",
    "drizzle-zod": "^0.8.3",
    "es-toolkit": "^1.42.0",
    "git-url-parse": "^16.1.0",
    "hono": "^4.10.7",
    "hono-rate-limiter": "^0.4.2",
    "ioredis": "^5.9.3",
    "isbot": "^5.1.31",
    "llamaindex": "~0.12.1",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "stoker": "^2.0.1",
    "uuidv7": "^1.1.0",
    "zod": "^4.1.13"
  }
}
