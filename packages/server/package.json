{
  "name": "@pcontext/server",
  "version": "0.0.4",
  "type": "module",
  "description": "PContext Server - CLI tool for starting the PContext service",
  "author": "fkcaikengren",
  "license": "MIT",
  "homepage": "https://github.com/fkcaikengren/pcontext#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fkcaikengren/pcontext.git",
    "directory": "packages/server"
  },
  "bugs": {
    "url": "https://github.com/fkcaikengren/pcontext/issues"
  },
  "bin": {
    "pcontext": "./bin/pcontext"
  },
  "main": "./dist/cli.js",
  "module": "./dist/cli.js",
  "exports": {
    ".": "./dist/cli.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist",
    "bin",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "init": "bun src/cli.ts emit-config",
    "dev": "bun src/cli.ts start --config ./pcontext.config.js",
    "build": "./scripts/build.sh",
    "start": "./bin/pcontext start --config ./pcontext.config.js",
    "start:node": "node dist/cli.js  start --config ./pcontext.config.js",
    "start:bun": "bun dist/cli.js  start --config ./pcontext.config.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@pcontext/api": "workspace:*",
    "@pcontext/shared": "workspace:*",
    "commander": "^14.0.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "pcontext",
    "server",
    "cli"
  ]
}
